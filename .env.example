# Discord bot token. Never commit a real token.
DISCORD_TOKEN=

# Numeric ID of the channel, e.g. 🌦️・flug-und-wetterlage
DISCORD_CHANNEL_ID=

# Default location: Lüneburg
WEATHER_LOCATION_NAME=Lüneburg
WEATHER_LATITUDE=53.2464
WEATHER_LONGITUDE=10.4115
WEATHER_TIMEZONE=Europe/Berlin

# Must divide 60 evenly. The bot updates at exact clock marks.
UPDATE_MINUTES=10

# Number of hourly forecast rows shown in the embed (1-12).
FORECAST_HOURS=6

LOG_LEVEL=INFO
